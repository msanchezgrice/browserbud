# ============================================================
# BrowserBud Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ------------------------------------------------------------
# PostHog Product Analytics
# Get your project API key from: https://app.posthog.com/project/settings
# ------------------------------------------------------------
VITE_POSTHOG_API_KEY=phc_your_project_api_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ------------------------------------------------------------
# Sentry Error Tracking (client-side)
# Get your DSN from: https://sentry.io/settings/<org>/projects/<project>/keys/
# ------------------------------------------------------------
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ------------------------------------------------------------
# Sentry Error Tracking (server-side / Vercel functions)
# Same DSN as above, but without the VITE_ prefix so it is
# NOT exposed to the browser bundle.
# ------------------------------------------------------------
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ------------------------------------------------------------
# Sentry Source Map Upload — CI/CD ONLY
# DO NOT add these to .env.local or any committed file.
# Set them as environment secrets in your CI/CD system (e.g.
# GitHub Actions / Vercel project settings).
# ------------------------------------------------------------
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug

# ------------------------------------------------------------
# Gemini AI (existing)
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001

# ------------------------------------------------------------
# Analytics API (existing)
# ------------------------------------------------------------
# BROWSERBUD_LOCAL_API_URL=http://127.0.0.1:3011
# BROWSERBUD_DATABASE_URL=postgres://user:pass@host/dbname
# BROWSERBUD_LOCAL_DB_PATH=data/browserbud.sqlite
