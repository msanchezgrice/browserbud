{
  "rewrites": [
    {
      "source": "/api/analytics/sessions/latest/timeline",
      "destination": "/api/analytics/sessions/latest/timeline"
    },
    {
      "source": "/api/analytics/sessions/:sessionId/timeline",
      "destination": "/api/analytics/sessions/[sessionId]/timeline"
    },
    {
      "source": "/api/analytics/sessions/:sessionId/recap",
      "destination": "/api/analytics/sessions/[sessionId]/recap"
    },
    {
      "source": "/api/analytics/sessions/:sessionId",
      "destination": "/api/analytics/sessions/[sessionId]"
    },
    {
      "source": "/app",
      "destination": "/"
    },
    {
      "source": "/app/:path*",
      "destination": "/"
    }
  ]
}
